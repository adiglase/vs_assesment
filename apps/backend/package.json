{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express backend for the court reporting workflow assessment.",
  "main": "dist/server.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run build:ts && tsc -p test/tsconfig.json && TS_NODE_PROJECT=test/tsconfig.json c8 node --test -r ts-node/register \"test/**/*.test.ts\"",
    "start": "npm run build:ts && node dist/server.js",
    "db:reset": "npm run build:ts && node dist/db/reset.js",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:ts",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "node --watch dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/supertest": "^7.2.0",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.4.0",
    "typescript": "~5.9.2"
  }
}
